# Visual Gate persistent env — sourced by design-kit/visual-gate.sh on startup.
# Created in S136 PHASE A step 5. Targets runmystore_sandbox tenant 999.
#
# Schema: shell-style KEY=VALUE, no spaces around `=`, no quotes needed for
# alphanumeric values. visual-gate.sh sources via `set -a; . file; set +a`
# so each variable is auto-exported to child processes (php -S).

VG_TENANT_ID=999
VG_STORE_ID=9990
VG_USER_ID=9990
VG_ROLE=owner
VG_USER_NAME="VG Sandbox Owner"

# DB routing — visual-gate-router.php uses this to override DB::$config so
# php -S targets runmystore_sandbox instead of production runmystore.
# auth-fixture defaults: tenant=1/store=1 against live DB → effectivePlan(false)
# fatal. With sandbox + tenant 999, we get a clean render path.
VG_DB_NAME=runmystore_sandbox
