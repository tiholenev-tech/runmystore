{
  "appId": "ai.runmystore.app",
  "appName": "RunMyStore",
  "webDir": "www",
  "server": {
    "url": "https://runmystore.ai",
    "androidScheme": "https",
    "allowNavigation": ["runmystore.ai", "*.runmystore.ai"],
    "cleartext": false
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": true,
    "loggingBehavior": "debug"
  },
  "plugins": {
    "BluetoothLe": {
      "displayStrings": {
        "scanning": "Търсене на принтер...",
        "cancel": "Отказ",
        "availableDevices": "Налични принтери",
        "noDeviceFound": "Принтер не е намерен"
      }
    }
  }
}
