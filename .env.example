# =====================================================
# S79.SECURITY — RunMyStore credentials template
# =====================================================
# Копирай тези файлове в /etc/runmystore/ и попълни реални стойности.
# НИКОГА не commit-вай реалните .env файлове в git!
#
# Setup:
#   sudo mkdir -p /etc/runmystore
#   sudo cp db.env.example /etc/runmystore/db.env
#   sudo cp api.env.example /etc/runmystore/api.env
#   sudo chmod 600 /etc/runmystore/*.env
#   sudo chown www-data:www-data /etc/runmystore/*.env
# =====================================================

# --- /etc/runmystore/db.env ---
DB_HOST=localhost
DB_NAME=runmystore
DB_USER=runmystore
DB_PASS="your_strong_password_here"

# --- /etc/runmystore/api.env ---
OPENAI_API_KEY="sk-proj-..."
OPENAI_MODEL="gpt-4o-mini"
GEMINI_API_KEY="AIzaSy..."
GEMINI_API_KEY_2="AIzaSy..."
GEMINI_MODEL="gemini-2.5-flash"
CLAUDE_API_KEY=""
